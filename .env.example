# Server
SERVER_PORT=9091

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# MySQL（含 & 时请勿用 shell source .env；由应用内 spring-dotenv 读取即可）
MYSQL_URL=jdbc:mysql://localhost:3306/report?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=interview

# 模版封面/底图上传根目录（空则默认 ~/myreport/uploads）
REPORT_TEMPLATE_UPLOAD_DIR=

# AI 简化报告：交付根目录（空则 files 下 report/simple-delivery/）
# allow-loopback 在 application.yml 中默认为 true；生产改为 false
# /demo/stat/* 本机地址始终允许（联调假数据）
SIMPLE_REPORT_DELIVERY_ROOT=

# QQ 邮箱发信（设置-账户-开启 SMTP 服务，生成授权码填入 MAIL_PASSWORD）
MAIL_ENABLED=TRUE
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=875657453@qq.com
MAIL_PASSWORD=maxtabdeuncobceg
MAIL_FROM_NAME=MyReport

# 通义千问（图表统计分析师；空则跳过 AI，回退 strText）
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
CHART_ANALYST_ENABLED=true
